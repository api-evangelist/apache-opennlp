{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-opennlp/refs/heads/main/json-structure/apache-opennlp-language-probability-structure.json",
  "description": "LanguageProbability schema from Apache OpenNLP",
  "type": "object",
  "properties": {
    "language": {
      "type": "string",
      "description": "ISO-639-3 language code",
      "example": "eng"
    },
    "probability": {
      "type": "double",
      "description": "Probability score",
      "example": 0.98
    }
  },
  "name": "LanguageProbability"
}